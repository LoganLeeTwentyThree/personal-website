---
const { path = '~' } = Astro.props;
const now = new Date();
const timestamp = now.toISOString().slice(0,19).replace('T', ' ');
---

<header class="shell-header">
  <div class="title-bar">
    <span class="dots">
      <span class="dot dot-red"></span>
      <span class="dot dot-yellow"></span>
      <span class="dot dot-green"></span>
    </span>
    <span class="title-text">bash — {path}</span>
  </div>
  <nav class="prompt-line">
    <span class="user">guest<span class="at">@</span>blog</span>
    <span class="sep">:</span>
    <span class="path">{path}</span>
    <span class="dollar">$</span>
    <span class="nav-links">
      <a href="/">ls ~/</a>
      <span class="dim"> | </span>
      <a href="/about">cat about.txt</a>
    </span>
  </nav>
  <div class="timestamp">last login: {timestamp}</div>
</header>

<style>
  .shell-header {
    border-bottom: 1px solid var(--border);
    padding: 0 0 12px 0;
    margin-bottom: 0;
  }

  .title-bar {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 8px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .dots {
    display: flex;
    gap: 6px;
    align-items: center;
  }

  .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }

  .dot-red    { background: #ff5f57; }
  .dot-yellow { background: #ffbd2e; }
  .dot-green  { background: #28c840; }

  .title-text {
    flex: 1;
    text-align: center;
    color: var(--text-dim);
    font-size: 12px;
    margin-left: -60px;
  }

  .prompt-line {
    padding: 10px 20px 2px;
    display: flex;
    align-items: center;
    gap: 0;
    flex-wrap: wrap;
  }

  .user {
    color: var(--green);
    font-weight: 700;
  }

  .at { color: var(--text-dim); }

  .sep {
    color: var(--text-dim);
    margin: 0 1px;
  }

  .path {
    color: #6699ff;
  }

  .dollar {
    color: var(--text-dim);
    margin: 0 8px 0 4px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .dim {
    color: var(--text-dim);
  }

  .timestamp {
    padding: 0 20px;
    color: var(--text-dim);
    font-size: 11px;
  }
</style>
