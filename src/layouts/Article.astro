---
import Base from './Base.astro';
import Shell from '../components/Shell.astro';
const { frontmatter } = Astro.props;
const { title, date, tags = [], description = '', slug, folder = '' } = frontmatter;
---

<Base title={`${title} — terminal.blog`} description={description}>
  <Shell path={`~/articles/${folder}/${slug}`} />

  <main class="container">
    <div class="breadcrumb dim">
      $ cat ~/articles/<span class="blue">{folder}/</span><span class="green">{slug}.md</span>
    </div>

    <article>
      <header class="article-header">
        <div class="meta">
          <span class="date dim">{date}</span>
          {tags.length > 0 && (
            <span class="tags">
              {tags.map((tag: string) => <span class="tag">[{tag}]</span>)}
            </span>
          )}
        </div>
        <h1 class="title">{title}</h1>
        {description && <p class="description dim"># {description}</p>}
        <div class="divider">{'─'.repeat(60)}</div>
      </header>

      <div class="prose">
        <slot />
      </div>
    </article>

    <div class="back-links">
      <span class="dim">$ </span><a href={`/folders/${folder}`}>cd ~/articles/{folder}</a>
      <span class="dim"> | </span>
      <a href="/">cd ~</a>
    </div>
  </main>
</Base>

<style>
  .container { max-width: 740px; margin: 0 auto; padding: 24px 20px 80px; }
  .breadcrumb { margin-bottom: 24px; font-size: 12px; }
  .green { color: var(--green); }
  .blue  { color: #6699ff; }

  .article-header { margin-bottom: 36px; }
  .meta { display: flex; gap: 12px; align-items: center; margin-bottom: 10px; font-size: 12px; }
  .tags { display: flex; gap: 6px; }
  .tag  { color: var(--amber); opacity: 0.8; }
  .title { font-size: clamp(18px, 3vw, 26px); font-weight: 700; color: #fff; line-height: 1.3; margin-bottom: 10px; }
  .description { font-size: 13px; margin-bottom: 16px; font-style: italic; }
  .divider { color: var(--border); font-size: 12px; letter-spacing: 1px; overflow: hidden; }

  .prose { font-size: 14px; line-height: 1.8; color: var(--text); }
  .prose :global(h2), .prose :global(h3) { color: var(--green); font-weight: 700; margin: 32px 0 12px; }
  .prose :global(h2)::before { content: '## '; color: var(--text-dim); }
  .prose :global(h3)::before { content: '### '; color: var(--text-dim); }
  .prose :global(p) { margin-bottom: 16px; }
  .prose :global(a) { color: var(--green); text-decoration: underline; }
  .prose :global(code) { background: var(--surface); border: 1px solid var(--border); padding: 1px 5px; border-radius: 2px; font-size: 13px; color: var(--amber); }
  .prose :global(pre) { background: var(--surface); border: 1px solid var(--border); border-left: 3px solid var(--green); padding: 16px; overflow-x: auto; margin: 20px 0; font-size: 13px; }
  .prose :global(pre code) { background: none; border: none; padding: 0; color: var(--text); }
  .prose :global(blockquote) { border-left: 3px solid var(--text-dim); padding-left: 16px; color: var(--text-dim); margin: 20px 0; font-style: italic; }
  .prose :global(ul), .prose :global(ol) { padding-left: 20px; margin-bottom: 16px; }
  .prose :global(li) { margin-bottom: 4px; }
  .prose :global(li)::marker { color: var(--green); }
  .prose :global(hr) { border: none; border-top: 1px solid var(--border); margin: 32px 0; }
  .prose :global(strong) { color: #fff; font-weight: 700; }
  .prose :global(img) { max-width: 100%; width: auto; height: auto; max-height: 480px; display: block; border: 1px solid var(--border); margin: 20px 0; }

  .back-links { margin-top: 48px; padding-top: 20px; border-top: 1px solid var(--border); font-size: 13px; }
  .dim { color: var(--text-dim); }
</style>