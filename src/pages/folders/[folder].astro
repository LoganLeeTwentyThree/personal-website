---
import Base from '../../layouts/Base.astro';
import Shell from '../../components/Shell.astro';

export async function getStaticPaths() {
  const allArticles = await Astro.glob('../../content/articles/**/*.md');

  // Build a map of folder -> articles
  const folderMap: Record<string, any[]> = {};

  for (const article of allArticles) {
    const parts = article.file.split('/content/articles/')[1].split('/');
    if (parts.length < 2) continue;
    const folder = parts[0];
    if (!folderMap[folder]) folderMap[folder] = [];
    folderMap[folder].push({
      title: article.frontmatter.title,
      slug: article.frontmatter.slug,
      date: article.frontmatter.date || '',
      tags: article.frontmatter.tags || [],
      description: article.frontmatter.description || '',
    });
  }

  return Object.entries(folderMap).map(([folder, articles]) => ({
    params: { folder },
    props: {
      folder,
      articles: articles.sort((a, b) => b.date.localeCompare(a.date)),
    },
  }));
}

const { folder, articles } = Astro.props;
---

<Base title={`/${folder} — terminal.blog`}>
  <Shell path={`~/articles/${folder}`} />

  <main class="container">
    <div class="cmd dim">$ ls -la ~/articles/{folder}/</div>
    <div class="ls-header dim">total {articles.length} {articles.length === 1 ? 'article' : 'articles'}</div>

    <ul class="article-list">
      {articles.map((article, i) => (
        <li class="article-row">
          <span class="index dim">{String(i + 1).padStart(2, '0')}.</span>
          <span class="perms dim">-rw-r--r--</span>
          <span class="date dim">{article.date}</span>
          <a class="title" href={`/articles/${folder}/${article.slug}`}>{article.title}</a>
          {article.tags.length > 0 && (
            <span class="tags">
              {article.tags.map((tag: string) => (
                <span class="tag">[{tag}]</span>
              ))}
            </span>
          )}
        </li>
      ))}
    </ul>

    <div class="footer-prompt">
      <span class="user-dim">guest@blog</span>
      <span class="dim">:~/articles/{folder}$ </span>
      <span class="cursor">▋</span>
    </div>

    <div class="back-link">
      <span class="dim">$ </span><a href="/">cd ~</a>
    </div>
  </main>
</Base>

<style>
  .container { max-width: 900px; margin: 0 auto; padding: 24px 20px 60px; }
  .cmd { font-size: 12px; margin-bottom: 4px; }
  .ls-header { font-size: 12px; margin-bottom: 16px; }
  .article-list { list-style: none; display: flex; flex-direction: column; }
  .article-row {
    display: flex; align-items: baseline; gap: 12px;
    padding: 5px 0; border-bottom: 1px solid transparent; flex-wrap: wrap;
  }
  .article-row:hover { border-bottom-color: var(--border); }
  .index { font-size: 11px; min-width: 22px; }
  .perms { font-size: 11px; letter-spacing: -0.5px; }
  .date  { font-size: 11px; min-width: 95px; }
  .title { color: var(--green); font-weight: 700; font-size: 14px; flex: 1; }
  .title:hover { color: #fff; text-decoration: none; }
  .tags { display: flex; gap: 6px; }
  .tag { color: var(--amber); font-size: 11px; opacity: 0.7; }
  .footer-prompt { margin-top: 32px; }
  .back-link { margin-top: 20px; font-size: 13px; }
  .user-dim { color: var(--green-dim); }
  .dim { color: var(--text-dim); }
  .cursor { color: var(--green); animation: blink 1.1s step-end infinite; }
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
</style>
